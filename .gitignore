# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
env/
venv/
ENV/

# IDE files
.DS_Store
.idea/
.vscode/

# Generated analytical results are intentionally versioned when each file is
# below GitHub's 100 MB hard limit. This keeps the manuscript, review layers,
# diagnostics, figures and machine-readable summaries available with the code.

# Large PDF outputs from manuscript compilation
*.aux
*.fdb_latexmk
*.fls
*.log
*.out

# Reproducible local caches and temporary rendering products
.pytest_cache/
tmp/
geophysical_cache/

# Geospatial data (original large source files - use smaller processed versions)
arcuate_geometries.geojson
african_impact_structures.geojson
astroblemes.geojson
